# Copy to .env for local development. Do not commit .env.

APP_ENV=local
LOG_LEVEL=INFO

# Mock services planned for later milestones.
MARKETING_PANEL_BASE_URL=http://localhost:8000
CAMPAIGN_API_BASE_URL=http://localhost:8001
ANALYTICS_GRAPHQL_URL=http://localhost:8002/graphql
PROJECT_MANAGEMENT_API_BASE_URL=http://localhost:8003

# Local mock marketing panel credentials.
MARKETING_PANEL_USERNAME=demo@example.com
MARKETING_PANEL_PASSWORD=local-password
MARKETING_PANEL_2FA_CODE=000000

# Optional integrations. Leave empty until configured locally.
LLM_INTERPRETATION_ENABLED=false
LLM_PROVIDER=mock
LLM_MODEL=deterministic-marketing-interpreter
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime behavior.
REQUEST_TIMEOUT_SECONDS=15
RETRY_MAX_ATTEMPTS=3
RATE_LIMIT_MAX_CALLS=10
RATE_LIMIT_PERIOD_SECONDS=1
